{
  "packageManager": "yarn@1.22.22",
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/eslint-parser": "^7.24.7",
    "@babel/eslint-plugin": "^7.24.7",
    "@babel/node": "^7.24.7",
    "@babel/plugin-transform-typescript": "^7.24.7",
    "@babel/runtime": "^7.24.7",
    "@types/jest": "^29.5.12",
    "@types/node": "^18.19.39",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "danger": "^12.3.3",
    "eslint": "^8.57.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-filenames": "^1.3.2",
    "eslint-plugin-flowtype": "^8.0.3",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-you-dont-need-lodash-underscore": "^6.14.0",
    "glob": "^10.4.2",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-extended": "^4.0.2",
    "jest-junit": "^16.0.0",
    "jest-serializer-path": "^0.1.15",
    "jest-silent-reporter": "^0.6.0",
    "joi": "^14.3.1",
    "js-yaml": "^3.14.1",
    "lerna": "^6.6.2",
    "lint-staged": "^15.2.7",
    "markdown-magic": "^2.6.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.8",
    "typescript": "^5.1.6",
    "unified": "^9.2.2"
  },
  "engines": {
    "yarn": "^1.17.3",
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "eslintIgnore": [
    "interfaces",
    "**/__tests__/fixtures/"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --ext .js,.jsx,.ts,.tsx --fix",
    "*.{md,css,scss,yaml,yml}": "prettier --write"
  },
  "private": true,
  "scripts": {
    "bootstrap": "cross-env COMPILER_OPTIONS=\"GATSBY_MAJOR=5\" npm-run-all -s \"lerna-prepare -- --{@}\" --",
    "check-publish-access": "node scripts/js/check-publish-access.js",
    "check-repo-fields": "node scripts/js/check-repo-fields.js",
    "check-versions": "node scripts/js/check-versions.js",
    "format": "npm run format:code && npm run format:other",
    "format:code": "npm run lint:code -- --fix",
    "format:other": "npm run prettier -- --write",
    "jest:inspect": "node --inspect node_modules/.bin/jest --runInBand",
    "jest:inspect-brk": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "lerna-prepare": "lerna run prepare --ignore gatsby-core-utils",
    "lint": "npm-run-all --continue-on-error -p lint:code lint:other",
    "lint:code": "eslint --ext .js,.jsx,.ts,.tsx --quiet .",
    "lint:other": "npm run prettier -- --check",
    "markdown": "md-magic --path \"starters/**/README.md\"",
    "postmarkdown": "prettier --write \"starters/**/README.md\"",
    "prebootstrap": "yarn && npm run check-versions && cross-env COMPILER_OPTIONS=\"GATSBY_MAJOR=5\" lerna run prepare --scope gatsby-core-utils",
    "prepare": "husky",
    "prettier": "prettier \"**/*.{md,css,scss,yaml,yml}\"",
    "publish": "echo \"Use 'yarn publish-next' or 'yarn publish-release' instead of 'yarn run publish'\"",
    "publish-canary": "npm run check-publish-access && lerna publish --canary --yes",
    "publish-next": "npm run check-publish-access && node scripts/js/clear-package-dir.js prerelease --verbose && cross-env COMPILER_OPTIONS=\"GATSBY_MAJOR=5\" lerna publish prerelease --pre-dist-tag=next --preid=next --allow-branch=master --message=\"chore(release): Publish next\"",
    "publish-preminor": "npm run check-publish-access && node scripts/js/clear-package-dir.js preminor --verbose && lerna publish preminor --pre-dist-tag=next --preid=next --force-publish --allow-branch=master --message=\"chore(release): Publish next pre-minor\"",
    "publish-rc": "npm run check-publish-access && node scripts/js/clear-package-dir prerelease --verbose && lerna publish prerelease --pre-dist-tag=rc --preid=rc --message=\"chore(release): Publish rc\"",
    "publish-release": "npm run check-publish-access && node scripts/js/clear-package-dir patch --verbose && lerna publish patch",
    "publish-premajor": "node scripts/js/release-next-major.js publish",
    "test": "npm-run-all --npm-path npm -s lint jest test:peril",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config=integration-tests/jest.config.js",
    "test:peril": "cd peril && yarn test",
    "test:update": "jest --updateSnapshot",
    "test:watch": "jest --watch",
    "typecheck": "node scripts/js/check-ts.mjs",
    "version": "node scripts/gatsby-changelog-generator/lerna-version-lifecycle.js && prettier --write \"**/CHANGELOG.md\"",
    "watch": "lerna run watch --no-sort --stream --concurrency 999"
  },
  "workspaces": [
    "packages/*",
    "scripts/*"
  ],
  "resolutions": {
    "@npmcli/arborist": "^7.5.3",
    "@npmcli/run-script": "^8.1.0",
    "@technote-space/doctoc": "^2.6.4",
    "esanimate": "^2.0.0",
    "libnpmpublish": "^7.5.2",
    "make-fetch-happen": "^13.0.1",
    "pacote": "^18.0.6",
    "tar": "^6.2.1"
  }
}
