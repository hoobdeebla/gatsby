{
  "name": "gatsby-graphiql-explorer",
  "version": "3.14.0-next.2",
  "description": "GraphiQL IDE with custom features for Gatsby users",
  "main": "index.js",
  "scripts": {
    "build": "webpack --config ./src/webpack.config.js",
    "watch": "npm run build -- --watch",
    "prepare": "cross-env NODE_ENV=production npm run clean && npm run build",
    "clean": "del-cli dist/*"
  },
  "keywords": [
    "gatsby",
    "graphiql",
    "gatsby-graphiql"
  ],
  "files": [
    "dist/*",
    "index.js"
  ],
  "author": "Michal Piechowiak <misiek.piechowiak@gmail.com>",
  "contributors": [
    "LekoArts"
  ],
  "bugs": {
    "url": "https://github.com/gatsbyjs/gatsby/issues"
  },
  "homepage": "https://github.com/gatsbyjs/gatsby/tree/master/packages/gatsby-graphiql-explorer#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/gatsbyjs/gatsby.git",
    "directory": "packages/gatsby-graphiql-explorer"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.25.9",
    "@babel/plugin-transform-class-properties": "^7.25.9",
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@babel/preset-env": "^7.25.9",
    "@babel/preset-react": "^7.25.9",
    "@graphiql/plugin-code-exporter": "^3.1.2",
    "@graphiql/plugin-explorer": "^3.2.2",
    "@graphiql/react": "^0.26.2",
    "@graphiql/toolkit": "^0.11.0",
    "babel-loader": "^9.2.1",
    "babel-preset-gatsby-package": "^3.14.0-next.2",
    "core-js": "^3.38.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "del-cli": "^6.0.0",
    "graphiql": "^3.7.1",
    "html-webpack-plugin": "^5.6.3",
    "npm-run-all": "^4.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "regenerator-runtime": "^0.14.1",
    "style-loader": "^4.0.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=14.15.0"
  }
}
